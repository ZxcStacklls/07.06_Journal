<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    android:background="#1a2a2a"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/photoImageView"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_launcher_round"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/uploadPhotoButton"
        android:layout_width="180dp"
        android:layout_height="40dp"
        android:text="Загрузить фото"
        android:textSize="12sp"
        android:backgroundTint="#2a9d8f"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/nameEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="ФИО"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/phoneEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Телефон"
        android:inputType="phone"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/emailEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/birthdayEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Дата рождения"
        android:inputType="date"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/addressEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Адрес"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/schoolEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Школа"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/socialEditText"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Ссылка на соц.сеть"
        android:inputType="textUri"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="* поля обязательные для заполнения"
        android:textColor="#FF5555"
        android:textSize="12sp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:text="Сохранить"
        android:textSize="16sp"
        android:backgroundTint="#2a9d8f" />

</LinearLayout>
